# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — password-protect the agent (leave empty for open access)
APP_PASSWORD=your_chosen_password

# Optional — where escalations go (leave empty to log only)
ESCALATION_EMAIL=support@yourclient.de

# Set automatically from config.json by agent.py — do not set manually
# COMPANY_NAME=
# PERSONA_NAME=
# LANGUAGE=

# Optional — SMTP for escalation emails
# If not set, escalations are logged to escalations.log only
SMTP_HOST=smtp.gmail.com
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
